# ============================================================
# EGAPP BACKEND — Variables de Entorno
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas el archivo .env al repositorio Git.
# ============================================================

# --- SERVIDOR ---
PORT=3000
NODE_ENV=development

# --- FIREBASE ADMIN SDK ---
# Descarga el JSON de credenciales desde: Firebase Console > Configuración > Cuentas de servicio
FIREBASE_PROJECT_ID=tu-proyecto-firebase
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@tu-proyecto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- SEGURIDAD: ENCRIPTACIÓN DE CREDENCIALES SUNAT ---
# Clave maestra de 32 caracteres para encriptar AES-256 las credenciales de cada empresa.
# Genera una clave segura con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=cambia_esto_por_una_clave_de_64_caracteres_hex

# --- REDIS (Para el sistema de colas BullMQ) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# --- SUNAT (Entorno de Pruebas o Producción) ---
SUNAT_API_BASE_URL=https://api-seguridad.sunat.gob.pe
SUNAT_TOKEN_URL=https://api-seguridad.sunat.gob.pe/v1/clientesextranet
SUNAT_GEM_URL=https://api-cpe.sunat.gob.pe/v1/contribuyente/gem
SUNAT_PORTAL_URL=https://e-menu.sunat.gob.pe/cl-ti-itmenu/MenuInternet.htm

# --- PLAYWRIGHT (RPA) ---
# true = Sin interfaz gráfica (producción en VPS Linux)
# false = Con interfaz gráfica (desarrollo local para depurar el bot)
PLAYWRIGHT_HEADLESS=false
